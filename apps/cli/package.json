{
  "name": "@pinyencheng/lhic",
  "version": "0.1.1",
  "description": "Local-first browser and global desktop intent controller for macOS, Windows, and Linux.",
  "license": "MIT OR Apache-2.0",
  "keywords": [
    "automation",
    "browser",
    "desktop",
    "macos",
    "windows",
    "linux"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chengmatt416/ComputerIntent.git"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "lhic": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -b",
    "prepack": "node ./scripts/clean-dist.mjs && npm run build && node ./scripts/prepare-package.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "bundleDependencies": [
    "@lhic/browser",
    "@lhic/memory",
    "@lhic/schema",
    "@lhic/security",
    "@lhic/skills",
    "@lhic/trace",
    "@lhic/verifier"
  ],
  "dependencies": {
    "@lhic/browser": "^0.1.0",
    "@lhic/memory": "^0.1.0",
    "@lhic/schema": "^0.1.0",
    "@lhic/security": "^0.1.0",
    "@lhic/skills": "^0.1.0",
    "@lhic/trace": "^0.1.0",
    "@lhic/verifier": "^0.1.0",
    "playwright": "^1.61.1"
  }
}
